# Database
MONGODB_URI=mongodb://prod-db-server:27017/task-management-prod

# JWT - Use STRONG secrets in production!
JWT_SECRET=your-super-strong-production-secret-key-at-least-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=8080
NODE_ENV=production

# Rate Limiting - Stricter in production
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Logging - Less verbose in production
LOG_LEVEL=warn